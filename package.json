{
  "name": "teamcast",
  "version": "0.6.0",
  "description": "CLI to design, generate, and validate Claude Code agent teams from a single manifest",
  "type": "module",
  "bin": {
    "teamcast": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
