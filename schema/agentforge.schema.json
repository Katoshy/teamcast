{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentforge.dev/schema/v2.json",
  "title": "AgentForge Manifest",
  "description": "Schema for agentforge.yaml and built-in preset manifests",
  "type": "object",
  "required": ["version", "project", "agents"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1", "2"],
      "description": "Manifest format version"
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "preset": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "agents": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "$ref": "#/definitions/AgentDefinition"
        }
      },
      "additionalProperties": false
    },
    "policies": {
      "$ref": "#/definitions/PoliciesConfig"
    },
    "settings": {
      "$ref": "#/definitions/GenerationSettings"
    },
    "preset_meta": {
      "$ref": "#/definitions/PresetMeta"
    }
  },
  "definitions": {
    "ModelAlias": {
      "type": "string",
      "enum": ["opus", "sonnet", "haiku", "inherit"]
    },
    "AgentSkill": {
      "type": "string",
      "enum": ["read_files", "write_files", "execute", "search", "web", "delegate", "interact", "notebook"]
    },
    "CanonicalTool": {
      "type": "string",
      "enum": [
        "Read", "Write", "Edit", "MultiEdit",
        "Grep", "Glob",
        "Bash",
        "WebFetch", "WebSearch",
        "Agent"
      ]
    },
    "CompatTool": {
      "type": "string",
      "enum": [
        "Read", "Write", "Edit", "MultiEdit",
        "Grep", "Glob",
        "Bash",
        "WebFetch", "WebSearch",
        "Agent", "Task"
      ]
    },
    "PermissionMode": {
      "type": "string",
      "enum": ["default", "acceptEdits", "bypassPermissions", "plan", "dontAsk"]
    },
    "InstructionBlockKind": {
      "type": "string",
      "enum": ["behavior", "workflow", "safety", "style", "delegation", "context", "custom"]
    },
    "PolicyAssertion": {
      "oneOf": [
        { "type": "object", "required": ["rule"], "properties": { "rule": { "const": "require_sandbox_with_execute" } }, "additionalProperties": false },
        { "type": "object", "required": ["rule", "skills"], "properties": { "rule": { "const": "forbid_skill_combination" }, "skills": { "type": "array", "items": { "$ref": "#/definitions/AgentSkill" }, "minItems": 2 } }, "additionalProperties": false },
        { "type": "object", "required": ["rule", "skill"], "properties": { "rule": { "const": "require_skill" }, "skill": { "$ref": "#/definitions/AgentSkill" } }, "additionalProperties": false },
        { "type": "object", "required": ["rule", "agent", "skill"], "properties": { "rule": { "const": "deny_skill_for_role" }, "agent": { "type": "string" }, "skill": { "$ref": "#/definitions/AgentSkill" } }, "additionalProperties": false },
        { "type": "object", "required": ["rule", "count"], "properties": { "rule": { "const": "max_agents" }, "count": { "type": "integer", "minimum": 1 } }, "additionalProperties": false },
        { "type": "object", "required": ["rule", "kind"], "properties": { "rule": { "const": "require_instruction_block" }, "kind": { "type": "string" } }, "additionalProperties": false },
        { "type": "object", "required": ["rule"], "properties": { "rule": { "const": "require_delegation_chain" } }, "additionalProperties": false },
        { "type": "object", "required": ["rule"], "properties": { "rule": { "const": "no_unrestricted_execute" } }, "additionalProperties": false }
      ]
    },
    "CapabilityTraitName": {
      "type": "string",
      "enum": [
        "base-read",
        "file-authoring",
        "command-execution",
        "web-research",
        "delegation",
        "no-file-edits",
        "no-commands",
        "no-web"
      ]
    },
    "InstructionFragmentName": {
      "type": "string",
      "enum": [
        "coordination-core",
        "delegate-first",
        "planning-core",
        "planning-read-only",
        "research-core",
        "research-citation",
        "research-no-file-edits",
        "development-core",
        "development-workflow",
        "tester-core",
        "tester-read-only",
        "review-core",
        "review-feedback",
        "security-audit-core",
        "security-audit-severity",
        "research-handoff",
        "secure-planning",
        "secure-development",
        "secure-development-tests",
        "security-review-gate",
        "post-audit-review",
        "solo-dev-core",
        "solo-dev-workflow",
        "solo-dev-style",
        "feature-orchestrator-workflow",
        "feature-orchestrator-output",
        "feature-planner-workflow",
        "feature-planner-read-only",
        "feature-developer-core",
        "feature-developer-workflow",
        "feature-developer-summary",
        "feature-reviewer-checklist",
        "feature-reviewer-style",
        "research-orchestrator-core",
        "research-orchestrator-workflow",
        "research-orchestrator-output",
        "research-planner-core",
        "research-planner-constraints",
        "research-developer-core",
        "research-developer-tests",
        "secure-orchestrator-core",
        "secure-orchestrator-workflow",
        "secure-orchestrator-gate",
        "post-audit-review-core"
      ]
    },
    "PolicyFragmentName": {
      "type": "string",
      "enum": [
        "allow-npm-run",
        "allow-npm-test",
        "allow-git-read",
        "allow-git-write",
        "allow-npx",
        "allow-npm-audit",
        "ask-git-push",
        "deny-destructive-shell",
        "deny-network-downloads",
        "deny-dynamic-exec",
        "deny-env-files",
        "sandbox-default"
      ]
    },
    "AbstractPermission": {
      "type": "string",
      "enum": [
        "project.commands",
        "tests",
        "git.read",
        "git.write",
        "package.exec",
        "security.audit",
        "git.push",
        "destructive-shell",
        "downloads",
        "dynamic-exec",
        "env.write"
      ]
    },
    "InstructionBlock": {
      "type": "object",
      "required": ["kind", "content"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/definitions/InstructionBlockKind"
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "LegacyToolsConfig": {
      "type": "object",
      "anyOf": [
        {
          "required": ["allow"],
          "properties": {
            "allow": {
              "type": "array",
              "items": { "$ref": "#/definitions/CompatTool" },
              "minItems": 1
            },
            "deny": {
              "type": "array",
              "items": { "$ref": "#/definitions/CompatTool" }
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["deny"],
          "properties": {
            "deny": {
              "type": "array",
              "items": { "$ref": "#/definitions/CompatTool" },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "McpServerConfig": {
      "type": "object",
      "required": ["name", "url"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "ClaudeAgentConfigV2": {
      "type": "object",
      "required": ["description"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "model": { "$ref": "#/definitions/ModelAlias" },
        "capability_traits": {
          "type": "array",
          "items": { "$ref": "#/definitions/CapabilityTraitName" }
        },
        "tools": {
          "type": "array",
          "items": {
            "anyOf": [
              { "$ref": "#/definitions/AgentSkill" },
              { "$ref": "#/definitions/CanonicalTool" }
            ]
          },
          "minItems": 1
        },
        "disallowed_tools": {
          "type": "array",
          "items": {
            "anyOf": [
              { "$ref": "#/definitions/AgentSkill" },
              { "$ref": "#/definitions/CanonicalTool" }
            ]
          }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "max_turns": {
          "type": "integer",
          "minimum": 1
        },
        "mcp_servers": {
          "type": "array",
          "items": { "$ref": "#/definitions/McpServerConfig" }
        },
        "permission_mode": {
          "$ref": "#/definitions/PermissionMode"
        },
        "instruction_fragments": {
          "type": "array",
          "items": { "$ref": "#/definitions/InstructionFragmentName" }
        },
        "instruction_blocks": {
          "type": "array",
          "items": { "$ref": "#/definitions/InstructionBlock" }
        },
        "background": {
          "type": "boolean"
        }
      }
    },
    "ClaudeAgentConfigV1": {
      "type": "object",
      "required": ["description"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "model": { "$ref": "#/definitions/ModelAlias" },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/definitions/CanonicalTool" },
          "minItems": 1
        },
        "disallowed_tools": {
          "type": "array",
          "items": { "$ref": "#/definitions/CanonicalTool" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "max_turns": {
          "type": "integer",
          "minimum": 1
        },
        "mcp_servers": {
          "type": "array",
          "items": { "$ref": "#/definitions/McpServerConfig" }
        },
        "permission_mode": {
          "$ref": "#/definitions/PermissionMode"
        },
        "instructions": {
          "type": "string"
        },
        "background": {
          "type": "boolean"
        }
      }
    },
    "ForgeAgentMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "handoffs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "role": { "type": "string" },
        "template": { "type": "string" }
      }
    },
    "CanonicalAgentConfigV2": {
      "type": "object",
      "required": ["claude"],
      "additionalProperties": false,
      "properties": {
        "claude": { "$ref": "#/definitions/ClaudeAgentConfigV2" },
        "forge": { "$ref": "#/definitions/ForgeAgentMetadata" }
      }
    },
    "CanonicalAgentConfigV1": {
      "type": "object",
      "required": ["claude"],
      "additionalProperties": false,
      "properties": {
        "claude": { "$ref": "#/definitions/ClaudeAgentConfigV1" },
        "forge": { "$ref": "#/definitions/ForgeAgentMetadata" }
      }
    },
    "LegacyAgentConfig": {
      "type": "object",
      "required": ["description"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "model": { "$ref": "#/definitions/ModelAlias" },
        "tools": { "$ref": "#/definitions/LegacyToolsConfig" },
        "skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "handoffs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "max_turns": {
          "type": "integer",
          "minimum": 1
        },
        "mcp_servers": {
          "type": "array",
          "items": { "$ref": "#/definitions/McpServerConfig" }
        },
        "permission_mode": {
          "$ref": "#/definitions/PermissionMode"
        },
        "behavior": {
          "type": "string"
        },
        "background": {
          "type": "boolean"
        }
      }
    },
    "AgentDefinition": {
      "anyOf": [
        { "$ref": "#/definitions/CanonicalAgentConfigV2" },
        { "$ref": "#/definitions/CanonicalAgentConfigV1" },
        { "$ref": "#/definitions/LegacyAgentConfig" }
      ]
    },
    "PermissionsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "anyOf": [
              { "$ref": "#/definitions/AbstractPermission" },
              { "type": "string" }
            ]
          }
        },
        "ask": {
          "type": "array",
          "items": {
            "anyOf": [
              { "$ref": "#/definitions/AbstractPermission" },
              { "type": "string" }
            ]
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "anyOf": [
              { "$ref": "#/definitions/AbstractPermission" },
              { "type": "string" }
            ]
          }
        },
        "default_mode": {
          "type": "string",
          "enum": ["default", "acceptEdits"]
        },
        "rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow": {
              "type": "array",
              "items": { "type": "string" }
            },
            "ask": {
              "type": "array",
              "items": { "type": "string" }
            },
            "deny": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "SandboxConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "auto_allow_bash": { "type": "boolean" },
        "excluded_commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow_unix_sockets": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allow_local_binding": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "HookEntry": {
      "type": "object",
      "required": ["matcher", "command"],
      "additionalProperties": false,
      "properties": {
        "matcher": { "type": "string" },
        "command": { "type": "string" },
        "async": { "type": "boolean" }
      }
    },
    "HooksConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pre_tool_use": {
          "type": "array",
          "items": { "$ref": "#/definitions/HookEntry" }
        },
        "post_tool_use": {
          "type": "array",
          "items": { "$ref": "#/definitions/HookEntry" }
        },
        "notification": {
          "type": "array",
          "items": { "$ref": "#/definitions/HookEntry" }
        }
      }
    },
    "NetworkConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_domains": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "PoliciesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fragments": {
          "type": "array",
          "items": { "$ref": "#/definitions/PolicyFragmentName" }
        },
        "permissions": { "$ref": "#/definitions/PermissionsConfig" },
        "sandbox": { "$ref": "#/definitions/SandboxConfig" },
        "hooks": { "$ref": "#/definitions/HooksConfig" },
        "network": { "$ref": "#/definitions/NetworkConfig" },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/definitions/PolicyAssertion" }
        }
      }
    },
    "GenerationSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_model": { "$ref": "#/definitions/ModelAlias" },
        "generate_docs": { "type": "boolean" },
        "generate_local_settings": { "type": "boolean" }
      }
    },
    "PresetMeta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "min_version": { "type": "string" }
      }
    }
  }
}
